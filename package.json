{
  "name": "@lenghanz/x-mcp",
  "version": "1.0.2",
  "description": "Read-only MCP server for X (Twitter) API",
  "main": "dist/index.js",
  "bin": {
    "x-mcp": "dist/index.js"
  },
  "type": "commonjs",
  "scripts": {
    "build": "tsc",
    "dev": "tsx --env-file=.env src/index.ts",
    "inspect": "npx @modelcontextprotocol/inspector tsx --env-file=.env src/index.ts",
    "start": "node dist/index.js",
    "prepare": "npm run build"
  },
  "keywords": ["mcp", "x", "twitter", "readonly"],
  "files": ["dist/"],
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.22.3",
    "typescript": "~5.4.0"
  }
}
